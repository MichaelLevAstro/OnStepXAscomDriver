<UserControl x:Class="ASCOM.OnStepX.Controls.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ASCOM.OnStepX.ViewModels"
             xmlns:cv="clr-namespace:ASCOM.OnStepX.Converters">
  <UserControl.Resources>
    <cv:ConsoleResponseBrushConverter x:Key="RespBrush"/>
    <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <cv:InverseBoolConverter x:Key="Invert"/>
  </UserControl.Resources>
  <Border Background="{DynamicResource Brush.Panel}"
          BorderBrush="{DynamicResource Brush.Border}"
          BorderThickness="0,1,0,0">
    <DockPanel LastChildFill="True">
      <!-- Toolbar / cmd input -->
      <Border DockPanel.Dock="Top"
              Background="{DynamicResource Brush.Panel}"
              Padding="14,10,14,10">
        <DockPanel LastChildFill="True">
          <CheckBox DockPanel.Dock="Left" Content="Show console"
                    IsChecked="{Binding ConsoleVisible}"
                    VerticalAlignment="Center" Margin="0,0,16,0"/>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
            <Button Style="{StaticResource Btn.SmPrimary}" Content="Send"
                    Command="{Binding SendCommand}" Margin="0,0,8,0"/>
          </StackPanel>
          <TextBox Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                   IsEnabled="{Binding MountActionsEnabled}"
                   FontFamily="{DynamicResource Font.Mono}"
                   FontSize="{DynamicResource Font.Size.Mono}"
                   Tag=":GVP#   — leading ':' and trailing '#' auto-added"
                   KeyDown="OnCmdInputKeyDown"/>
        </DockPanel>
      </Border>

      <!-- Section-style header for the console body (with controls on right) -->
      <Border DockPanel.Dock="Top"
              Visibility="{Binding ConsoleVisible, Converter={StaticResource BoolToVis}}"
              Background="{DynamicResource Brush.Panel2}"
              BorderBrush="{DynamicResource Brush.Border}"
              BorderThickness="0,1,0,0"
              Padding="14,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"
                  Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.6"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  Data="{StaticResource Geo.Console}"/>
            <TextBlock Style="{StaticResource Text.SectionTitle}"
                       Text="CONSOLE"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
            <CheckBox Content="Enabled"     IsChecked="{Binding IoEnabled}"   Margin="0,0,12,0"/>
            <CheckBox Content="Auto-scroll" IsChecked="{Binding AutoScroll}"  Margin="0,0,12,0"/>
            <TextBox Width="180" Height="24" FontSize="11.5"
                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Filter (case-sensitive)"
                     Margin="0,0,6,0"/>
            <Button Style="{StaticResource Btn.Sm}" Content="Clear filter" Command="{Binding ClearFilterCommand}" Margin="0,0,12,0"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Style="{StaticResource Btn.Sm}" Content="Copy"  Command="{Binding CopyCommand}"  Margin="0,0,6,0"/>
            <Button Style="{StaticResource Btn.Sm}" Content="Clear" Command="{Binding ClearCommand}"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Virtualized log list -->
      <Border Background="{DynamicResource Brush.ConsoleBg}"
              Visibility="{Binding ConsoleVisible, Converter={StaticResource BoolToVis}}"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0">
        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Height="220">
          <ItemsControl ItemsSource="{Binding Entries}"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        ScrollViewer.CanContentScroll="True">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:ConsoleEntry}">
                <Grid Margin="14,2,14,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Timestamp}"
                             FontFamily="{DynamicResource Font.Mono}" FontSize="12"
                             Foreground="{DynamicResource Brush.ColTs}"/>
                  <TextBlock Grid.Column="1" Text="{Binding Command}"
                             FontFamily="{DynamicResource Font.Mono}" FontSize="12"
                             Foreground="{DynamicResource Brush.ColCmd}"/>
                  <TextBlock Grid.Column="2" Text="→"
                             FontFamily="{DynamicResource Font.Mono}" FontSize="12"
                             Foreground="{DynamicResource Brush.TextFaint}"
                             Visibility="{Binding Command, Converter={StaticResource BoolToVis}}"/>
                  <TextBlock Grid.Column="3" Text="{Binding Response}"
                             FontFamily="{DynamicResource Font.Mono}" FontSize="12"
                             Foreground="{Binding Kind, Converter={StaticResource RespBrush}}"
                             TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="4" Text="{Binding Elapsed}"
                             TextAlignment="Right"
                             FontFamily="{DynamicResource Font.Mono}" FontSize="12"
                             Foreground="{DynamicResource Brush.ColMeta}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </DockPanel>
  </Border>
</UserControl>
