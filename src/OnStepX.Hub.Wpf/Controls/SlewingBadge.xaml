<UserControl x:Class="ASCOM.OnStepX.Controls.SlewingBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             VerticalAlignment="Center">
  <UserControl.Resources>
    <Storyboard x:Key="Radar1" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="R1Scale" Storyboard.TargetProperty="ScaleX" From="0.2" To="1.1" Duration="0:0:1.6"/>
      <DoubleAnimation Storyboard.TargetName="R1Scale" Storyboard.TargetProperty="ScaleY" From="0.2" To="1.1" Duration="0:0:1.6"/>
      <DoubleAnimation Storyboard.TargetName="R1" Storyboard.TargetProperty="Opacity" From="1.0" To="0.0" Duration="0:0:1.6"/>
    </Storyboard>
    <Storyboard x:Key="Radar2" RepeatBehavior="Forever" BeginTime="0:0:0.8">
      <DoubleAnimation Storyboard.TargetName="R2Scale" Storyboard.TargetProperty="ScaleX" From="0.2" To="1.1" Duration="0:0:1.6"/>
      <DoubleAnimation Storyboard.TargetName="R2Scale" Storyboard.TargetProperty="ScaleY" From="0.2" To="1.1" Duration="0:0:1.6"/>
      <DoubleAnimation Storyboard.TargetName="R2" Storyboard.TargetProperty="Opacity" From="1.0" To="0.0" Duration="0:0:1.6"/>
    </Storyboard>
  </UserControl.Resources>
  <Border Background="{DynamicResource Brush.AccentSoft}"
          BorderBrush="{DynamicResource Brush.Accent}" BorderThickness="1"
          CornerRadius="6" Padding="8,3">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
      <Grid Width="14" Height="14" Margin="0,0,8,0">
        <Ellipse x:Name="R1" Width="14" Height="14"
                 Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.5" RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform><ScaleTransform x:Name="R1Scale" ScaleX="0.2" ScaleY="0.2"/></Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="R2" Width="14" Height="14"
                 Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.5" RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform><ScaleTransform x:Name="R2Scale" ScaleX="0.2" ScaleY="0.2"/></Ellipse.RenderTransform>
        </Ellipse>
      </Grid>
      <TextBlock Text="Slewing" Foreground="{DynamicResource Brush.Text}" FontWeight="Medium"/>
      <TextBlock Text="{Binding Coord, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Foreground="{DynamicResource Brush.TextDim}"
                 FontFamily="{DynamicResource Font.Mono}" FontSize="11"
                 Margin="8,0,0,0"/>
    </StackPanel>
  </Border>
</UserControl>
