<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Source of truth: Ui/Theming/Theme.cs:83-119. Hex values are 1:1 with
       the WinForms palette so the WPF hub matches the legacy hub byte-for-byte
       in dark mode and the design's reference rendering. -->

  <SolidColorBrush x:Key="Brush.Bg"               Color="#14171c"/>
  <SolidColorBrush x:Key="Brush.Panel"            Color="#1b1f26"/>
  <SolidColorBrush x:Key="Brush.Panel2"           Color="#1f242d"/>
  <SolidColorBrush x:Key="Brush.PanelInset"       Color="#10131a"/>
  <SolidColorBrush x:Key="Brush.Border"           Color="#2a313c"/>
  <SolidColorBrush x:Key="Brush.BorderStrong"     Color="#3a4250"/>

  <SolidColorBrush x:Key="Brush.Text"             Color="#e6ebf2"/>
  <SolidColorBrush x:Key="Brush.TextDim"          Color="#9aa4b2"/>
  <SolidColorBrush x:Key="Brush.TextFaint"        Color="#6b7582"/>
  <SolidColorBrush x:Key="Brush.Label"            Color="#8a94a3"/>

  <SolidColorBrush x:Key="Brush.Accent"           Color="#e5482d"/>
  <SolidColorBrush x:Key="Brush.AccentInk"        Color="#ffffff"/>
  <SolidColorBrush x:Key="Brush.AccentSoft"       Color="#1Fe5482d"/>

  <SolidColorBrush x:Key="Brush.Danger"           Color="#e5482d"/>
  <SolidColorBrush x:Key="Brush.Ok"               Color="#4ac27a"/>
  <SolidColorBrush x:Key="Brush.Warn"             Color="#d4b34a"/>
  <SolidColorBrush x:Key="Brush.Info"             Color="#5f9ed4"/>

  <SolidColorBrush x:Key="Brush.InputBg"          Color="#0f1218"/>
  <SolidColorBrush x:Key="Brush.InputBorder"      Color="#323a47"/>
  <SolidColorBrush x:Key="Brush.InputBorderHover" Color="#4a5362"/>

  <SolidColorBrush x:Key="Brush.BtnBg"            Color="#242a33"/>
  <SolidColorBrush x:Key="Brush.BtnBgHover"       Color="#2c333e"/>
  <SolidColorBrush x:Key="Brush.BtnBgActive"      Color="#323a46"/>

  <SolidColorBrush x:Key="Brush.Chip"             Color="#242a33"/>

  <SolidColorBrush x:Key="Brush.ConsoleBg"        Color="#0b0d12"/>
  <SolidColorBrush x:Key="Brush.ConsoleLine"      Color="#141821"/>

  <SolidColorBrush x:Key="Brush.ScrollTrack"      Color="#181c24"/>
  <SolidColorBrush x:Key="Brush.ScrollThumb"      Color="#39414f"/>
  <SolidColorBrush x:Key="Brush.ScrollThumbHover" Color="#4a5362"/>

  <SolidColorBrush x:Key="Brush.ColTs"            Color="#6b98e0"/>
  <SolidColorBrush x:Key="Brush.ColCmd"           Color="#e8b86d"/>
  <SolidColorBrush x:Key="Brush.ColResp"          Color="#8bd0a0"/>
  <SolidColorBrush x:Key="Brush.ColMeta"          Color="#8a94a3"/>

  <Color x:Key="Color.Accent">#e5482d</Color>
  <Color x:Key="Color.Ok">#4ac27a</Color>
  <Color x:Key="Color.Warn">#d4b34a</Color>
  <Color x:Key="Color.Danger">#e5482d</Color>
  <Color x:Key="Color.Info">#5f9ed4</Color>

</ResourceDictionary>
