<UserControl x:Class="ASCOM.OnStepX.Controls.MountVisualizer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
             xmlns:cv="clr-namespace:ASCOM.OnStepX.Converters"
             Background="{DynamicResource Brush.PanelInset}"
             Focusable="False">
  <UserControl.Resources>
    <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
  </UserControl.Resources>
  <Grid>
    <helix:HelixViewport3D x:Name="Viewport"
                           ShowCoordinateSystem="False"
                           ShowFrameRate="False"
                           ShowViewCube="False"
                           ZoomExtentsWhenLoaded="True"
                           IsHeadLightEnabled="False"
                           CameraRotationMode="Trackball"
                           RotateAroundMouseDownPoint="True"
                           ZoomAroundMouseDownPoint="True"
                           Background="Transparent">
      <helix:HelixViewport3D.RotateGesture>
        <MouseGesture MouseAction="LeftClick"/>
      </helix:HelixViewport3D.RotateGesture>
      <helix:HelixViewport3D.PanGesture>
        <MouseGesture MouseAction="RightClick"/>
      </helix:HelixViewport3D.PanGesture>
      <helix:DefaultLights/>
    </helix:HelixViewport3D>

    <!-- HUD overlay: HA / Dec readouts -->
    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="8" IsHitTestVisible="False">
      <TextBlock Foreground="{DynamicResource Brush.TextDim}" FontSize="10"
                 Text="{Binding RaAxisAngleDeg, StringFormat='Axis 1 (HA): {0,7:+0.00;-0.00; 0.00}°'}"
                 FontFamily="Consolas, Courier New"/>
      <TextBlock Foreground="{DynamicResource Brush.TextDim}" FontSize="10"
                 Text="{Binding DecAxisAngleDeg, StringFormat='Axis 2 (Dec): {0,7:+0.00;-0.00; 0.00}°'}"
                 FontFamily="Consolas, Courier New"/>
      <TextBlock Foreground="{DynamicResource Brush.TextFaint}" FontSize="10"
                 Text="{Binding PierSide, StringFormat='Pier: {0}'}"
                 FontFamily="Consolas, Courier New"/>
    </StackPanel>

    <!-- Disconnect dim overlay -->
    <Rectangle Fill="{DynamicResource Brush.Bg}" Opacity="0.5"
               IsHitTestVisible="False"
               Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
  </Grid>
</UserControl>
