<UserControl x:Class="ASCOM.OnStepX.Controls.SlewPad"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
  <UserControl.Resources>
    <Style x:Key="SlewBtn" TargetType="Button">
      <Setter Property="Height" Value="64"/>
      <Setter Property="Background" Value="{DynamicResource Brush.BtnBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource Size.RadiusLg}"
                    SnapsToDevicePixels="True">
              <Grid>
                <TextBlock Text="{TemplateBinding Tag}"
                           HorizontalAlignment="Left" VerticalAlignment="Top"
                           Margin="8,6,0,0"
                           FontFamily="{DynamicResource Font.Mono}"
                           FontSize="10" FontWeight="Normal"
                           Foreground="{DynamicResource Brush.TextFaint}"/>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                  TextElement.FontWeight="{TemplateBinding FontWeight}"
                                  TextElement.FontSize="{TemplateBinding FontSize}"/>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.BtnBgHover}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.InputBorderHover}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="RenderTransform">
                  <Setter.Value><TranslateTransform Y="1"/></Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
                <Setter Property="Cursor" Value="Arrow"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="StopBtn" TargetType="Button" BasedOn="{StaticResource SlewBtn}">
      <Setter Property="Background" Value="{DynamicResource Brush.Accent}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.AccentInk}"/>
    </Style>
  </UserControl.Resources>
  <UniformGrid Rows="3" Columns="3"
               x:Name="PadGrid">
    <UniformGrid.Resources>
      <Thickness x:Key="PadGap">3</Thickness>
    </UniformGrid.Resources>
    <Button Tag="↖" Margin="0,0,3,3" Style="{StaticResource SlewBtn}" Content="NW"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="NW"/>
    <Button Tag="↑" Margin="3,0,3,3" Style="{StaticResource SlewBtn}" Content="N"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="N"/>
    <Button Tag="↗" Margin="3,0,0,3" Style="{StaticResource SlewBtn}" Content="NE"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="NE"/>

    <Button Tag="←" Margin="0,3,3,3" Style="{StaticResource SlewBtn}" Content="W"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="W"/>
    <Button Margin="3" Style="{StaticResource StopBtn}" Content="STOP" x:Name="StopButton"
            Click="OnStop"/>
    <Button Tag="→" Margin="3,3,0,3" Style="{StaticResource SlewBtn}" Content="E"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="E"/>

    <Button Tag="↙" Margin="0,3,3,0" Style="{StaticResource SlewBtn}" Content="SW"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="SW"/>
    <Button Tag="↓" Margin="3,3,3,0" Style="{StaticResource SlewBtn}" Content="S"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="S"/>
    <Button Tag="↘" Margin="3,3,0,0" Style="{StaticResource SlewBtn}" Content="SE"
            PreviewMouseLeftButtonDown="OnPress" PreviewMouseLeftButtonUp="OnRelease"
            MouseLeave="OnRelease" CommandParameter="SE"/>
  </UniformGrid>
</UserControl>
