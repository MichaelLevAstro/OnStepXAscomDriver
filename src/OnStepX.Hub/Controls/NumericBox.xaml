<UserControl x:Class="ASCOM.OnStepX.Controls.NumericBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="28">
  <Border x:Name="OuterBorder"
          Background="{DynamicResource Brush.InputBg}"
          BorderBrush="{DynamicResource Brush.InputBorder}"
          BorderThickness="1"
          CornerRadius="4"
          SnapsToDevicePixels="True">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBox x:Name="ValueTextBox"
               Grid.Column="0"
               BorderThickness="0"
               Background="Transparent"
               Padding="8,0"
               TextAlignment="Right"
               VerticalContentAlignment="Center"
               FontFamily="{DynamicResource Font.Mono}"
               FontSize="{DynamicResource Font.Size.Mono}"
               Foreground="{DynamicResource Brush.Text}"
               CaretBrush="{DynamicResource Brush.Text}"
               LostFocus="OnTextLostFocus"
               KeyDown="OnTextKeyDown"
               PreviewMouseWheel="OnMouseWheel"/>
      <StackPanel Grid.Column="1" Orientation="Vertical" Width="14" Margin="0,1,1,1">
        <RepeatButton Style="{StaticResource RepeatBtn.Spinner}"
                      Height="13" Click="OnUpClick">
          <Path Width="6" Height="4" Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                StrokeThickness="1.4"
                StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                Data="M0 4 L3 0 L6 4"/>
        </RepeatButton>
        <RepeatButton Style="{StaticResource RepeatBtn.Spinner}"
                      Height="13" Click="OnDownClick">
          <Path Width="6" Height="4" Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                StrokeThickness="1.4"
                StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                Data="M0 0 L3 4 L6 0"/>
        </RepeatButton>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
