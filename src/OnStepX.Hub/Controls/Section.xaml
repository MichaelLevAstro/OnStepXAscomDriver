<UserControl x:Class="ASCOM.OnStepX.Controls.Section"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:ASCOM.OnStepX.Controls"
             Focusable="False"
             Margin="0,0,0,8">
  <Border Style="{StaticResource Section.Card}">
    <StackPanel>
      <Border x:Name="HeaderBorder"
              Background="Transparent" Cursor="Hand"
              MouseLeftButtonUp="OnHeaderClick"
              Padding="{StaticResource Size.SectionHeaderPad}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>  <!-- Icon -->
            <ColumnDefinition Width="*"/>     <!-- Title -->
            <ColumnDefinition Width="Auto"/>  <!-- Header right slot -->
            <ColumnDefinition Width="Auto"/>  <!-- Chevron -->
          </Grid.ColumnDefinitions>
          <Path x:Name="IconPath" Grid.Column="0"
                Width="14" Height="14" Margin="0,0,8,0"
                Stretch="Uniform"
                Stroke="{DynamicResource Brush.Accent}"
                StrokeThickness="1.6"
                StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                Data="{Binding IconGeometry, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
          <TextBlock x:Name="TitleText" Grid.Column="1"
                     Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Style="{StaticResource Text.SectionTitle}"
                     VerticalAlignment="Center"
                     TextOptions.TextFormattingMode="Display"
                     FontSize="11.5"
                     Foreground="{DynamicResource Brush.Text}"/>
          <ContentPresenter Grid.Column="2"
                            Content="{Binding HeaderRight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Margin="0,0,8,0" VerticalAlignment="Center"/>
          <Path x:Name="Chevron" Grid.Column="3"
                Width="12" Height="8"
                Stretch="Uniform"
                Stroke="{DynamicResource Brush.TextFaint}" StrokeThickness="1.4"
                StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                Data="M2 4 L6 8 L10 4"
                RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform><RotateTransform x:Name="ChevRot" Angle="0"/></Path.RenderTransform>
          </Path>
        </Grid>
      </Border>
      <Border x:Name="BodyBorder"
              BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource Brush.Border}"
              Padding="{StaticResource Size.SectionPad}"
              Visibility="Visible">
        <ContentPresenter Content="{Binding Body, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
