<UserControl x:Class="ASCOM.OnStepX.Controls.PulseDot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="20" Height="20"
             Focusable="False"
             SnapsToDevicePixels="True"
             ClipToBounds="False">
  <!-- 20x20 host gives the halo ~10px radius headroom at peak scale; the
       parent section Border has CornerRadius=6 which clips overflow, so
       the halo must stay inside the control's box (was clipping at the top
       before with the previous 14x14 size + 2.0 scale animation). -->
  <Grid ClipToBounds="False">
    <!-- Halo: scales+fades when Pulsing=true && Status=Ok. Storyboard kicked
         off in code-behind so it tracks the brush color when theme swaps. -->
    <Ellipse x:Name="Halo"
             Width="14" Height="14"
             HorizontalAlignment="Center" VerticalAlignment="Center"
             Fill="{Binding StatusBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
             Opacity="0.25"
             RenderTransformOrigin="0.5,0.5">
      <Ellipse.RenderTransform>
        <ScaleTransform x:Name="HaloScale" ScaleX="1" ScaleY="1"/>
      </Ellipse.RenderTransform>
    </Ellipse>
    <Ellipse Width="8" Height="8"
             HorizontalAlignment="Center" VerticalAlignment="Center"
             Fill="{Binding StatusBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
  </Grid>
</UserControl>
