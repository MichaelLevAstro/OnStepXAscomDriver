<Window x:Class="ASCOM.OnStepX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:ASCOM.OnStepX.Controls"
        xmlns:vm="clr-namespace:ASCOM.OnStepX.ViewModels"
        xmlns:cv="clr-namespace:ASCOM.OnStepX.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="OnStepX ASCOM Driver"
        Width="1280" Height="780"
        MinWidth="1100" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="{DynamicResource Font.Sans}" FontSize="13"
        TextOptions.TextFormattingMode="Display"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="38" GlassFrameThickness="0"
                        UseAeroCaptionButtons="False" CornerRadius="0" ResizeBorderThickness="6"/>
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <cv:InverseBoolConverter x:Key="Invert"/>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
    <DockPanel LastChildFill="True">
      <c:TitleBar DockPanel.Dock="Top"/>

      <!-- Console at the bottom (DockPanel order matters: console docks before
           the body so the body fills remaining space). -->
      <c:ConsoleView DockPanel.Dock="Bottom" DataContext="{Binding Console}"/>

      <!-- Three-column section grid: LEFT (mount config) | MIDDLE (mount live ops) | RIGHT (focuser, future devices). -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT pane -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14">
          <StackPanel>
            <!-- ───── Connection ───── -->
            <c:Section Title="CONNECTION" IconGeometry="{StaticResource Geo.Connection}">
              <c:Section.HeaderRight>
                <c:StatusBadge Status="{Binding Connection.StatusKind}"
                               Pulsing="{Binding Connection.StatusPulse}"
                               Text="{Binding Connection.StatusText}"/>
              </c:Section.HeaderRight>
              <c:Section.Body>
                <StackPanel>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="92"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Transport" Style="{StaticResource Text.Label}"/>
                    <ComboBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                              ItemsSource="{Binding Connection.Transports}"
                              SelectedItem="{Binding Connection.TransportKind}"
                              IsEnabled="{Binding Connection.TransportFieldsEnabled}"/>
                  </Grid>
                  <Grid Margin="0,0,0,6" Visibility="{Binding Connection.IsSerial, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="92"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="COM port" Style="{StaticResource Text.Label}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <ComboBox Width="110" IsEditable="True"
                                ItemsSource="{Binding Connection.ComPorts}"
                                Text="{Binding Connection.SerialPort, UpdateSourceTrigger=LostFocus}"
                                IsEnabled="{Binding Connection.TransportFieldsEnabled}"
                                DropDownOpened="ComPortDropDownOpened"
                                Margin="0,0,8,0"/>
                      <TextBlock Text="Baud" Style="{StaticResource Text.Label}" Margin="0,0,6,0"/>
                      <c:NumericBox Width="92" Min="1200" Max="460800" Step="1200"
                                    Value="{Binding Connection.SerialBaud}"
                                    IsEnabled="{Binding Connection.TransportFieldsEnabled}"/>
                    </StackPanel>
                  </Grid>
                  <Grid Margin="0,0,0,6" Visibility="{Binding Connection.IsTcp, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="92"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="TCP host / port" Style="{StaticResource Text.Label}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBox Width="170"
                               Text="{Binding Connection.TcpHost, UpdateSourceTrigger=LostFocus}"
                               IsEnabled="{Binding Connection.TransportFieldsEnabled}"
                               Margin="0,0,8,0"/>
                      <c:NumericBox Width="72" Min="1" Max="65535" Step="1"
                                    Value="{Binding Connection.TcpPort}"
                                    IsEnabled="{Binding Connection.TransportFieldsEnabled}"/>
                    </StackPanel>
                  </Grid>
                  <StackPanel Orientation="Horizontal" Margin="0,4,0,6">
                    <Button Style="{StaticResource Btn.Sm}" Content="{Binding Connection.AutoDetectButtonText}"
                            Command="{Binding Connection.AutoDetectCommand}" Margin="0,0,6,0"/>
                    <Button Style="{StaticResource Btn.Sm}" Content="Connect"
                            Command="{Binding Connection.ConnectCommand}" Margin="0,0,6,0"/>
                    <Button Style="{StaticResource Btn.SmPrimary}" Content="Disconnect"
                            Command="{Binding Connection.DisconnectCommand}"/>
                  </StackPanel>
                  <CheckBox Content="Auto-connect to saved port on open"
                            IsChecked="{Binding Connection.AutoConnect}"/>
                </StackPanel>
              </c:Section.Body>
            </c:Section>

            <!-- ───── Site ───── -->
            <c:Section Title="SITE" IconGeometry="{StaticResource Geo.Site}">
              <c:Section.Body>
                <StackPanel>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Latitude" Style="{StaticResource Text.Label}"/>
                    <TextBox Grid.Column="1" Text="{Binding Site.Latitude, UpdateSourceTrigger=LostFocus}"/>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Longitude" Style="{StaticResource Text.Label}"/>
                    <TextBox Grid.Column="1" Text="{Binding Site.Longitude, UpdateSourceTrigger=LostFocus}"/>
                  </Grid>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Elevation (m)" Style="{StaticResource Text.Label}"/>
                    <TextBox Grid.Column="1" Text="{Binding Site.Elevation, UpdateSourceTrigger=LostFocus}"/>
                  </Grid>
                  <UniformGrid Columns="3" HorizontalAlignment="Stretch">
                    <Button Content="{Binding Site.SyncFromPcText}" Command="{Binding Site.SyncFromPcCommand}" Margin="0,0,6,0"/>
                    <Button Content="Upload" Command="{Binding Site.UploadCommand}" Margin="0,0,6,0"/>
                    <Button Content="Sites…" Command="{Binding Site.SitesCommand}"/>
                  </UniformGrid>
                </StackPanel>
              </c:Section.Body>
            </c:Section>

            <!-- ───── Date / Time ───── -->
            <c:Section Title="DATE / TIME" IconGeometry="{StaticResource Geo.Clock}">
              <c:Section.Body>
                <StackPanel>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Local" Style="{StaticResource Text.Label}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <!-- Plain text fields. The 250 ms VM tick keeps these
                           rolling forward when not focused; the user typically
                           uses "Sync from PC" and never touches them. -->
                      <TextBox Width="120" Margin="0,0,6,0"
                               Text="{Binding DateTime.LocalDateText, UpdateSourceTrigger=LostFocus}"
                               ToolTip="dd/MM/yyyy"/>
                      <TextBox Width="100"
                               Text="{Binding DateTime.LocalTimeText, UpdateSourceTrigger=LostFocus}"
                               ToolTip="HH:mm:ss"/>
                    </StackPanel>
                  </Grid>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Timezone (h)" Style="{StaticResource Text.Label}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <c:NumericBox Width="80" Min="-14" Max="14" Step="0.5" DecimalPlaces="1"
                                    Value="{Binding DateTime.UtcOffsetHours}"/>
                      <Button Content="Sync from PC" Command="{Binding DateTime.SyncFromPcCommand}" Margin="8,0,0,0"/>
                    </StackPanel>
                  </Grid>
                  <Button Content="Upload" Command="{Binding DateTime.UploadCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                  <CheckBox Content="Auto-sync date/time from PC on connect"
                            IsChecked="{Binding DateTime.AutoSyncOnConnect}"/>
                </StackPanel>
              </c:Section.Body>
            </c:Section>

            <!-- ───── Tracking / Slew ───── -->
            <c:Section Title="TRACKING / SLEW" IconGeometry="{StaticResource Geo.Tracking}">
              <c:Section.Body>
                <StackPanel>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <CheckBox Content="Tracking enabled" IsChecked="{Binding Tracking.TrackingEnabled}"
                              IsEnabled="{Binding Tracking.MountActionsEnabled}"
                              VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Grid Grid.Column="1">
                      <c:StatusBadge Status="{Binding Tracking.StateKind}"
                                     Pulsing="{Binding Tracking.StatePulse}"
                                     Text="{Binding Tracking.StateText}"
                                     Visibility="{Binding Tracking.IsSlewing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                      <c:SlewingBadge Coord="{Binding Tracking.SlewCoord}"
                                      Visibility="{Binding Tracking.IsSlewing, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Tracking rate" Style="{StaticResource Text.Label}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Tracking.TrackingModes}"
                              SelectedItem="{Binding Tracking.TrackingMode}"
                              IsEnabled="{Binding Tracking.MountActionsEnabled}"/>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Slew (°/s)" Style="{StaticResource Text.Label}"/>
                    <c:NumericBox Grid.Column="1" Width="72"
                                  Min="{Binding Tracking.SlewRateMin}" Max="{Binding Tracking.SlewRateMax}"
                                  Step="0.25" DecimalPlaces="2"
                                  Value="{Binding Tracking.SlewRate}"/>
                    <TextBlock Grid.Column="2" Text="×" Margin="6,0" Style="{StaticResource Text.Hint}"/>
                    <Slider Grid.Column="3"
                            Minimum="{Binding Tracking.SlewRateMin}" Maximum="{Binding Tracking.SlewRateMax}"
                            Value="{Binding Tracking.SlewRate}"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding Tracking.MountActionsEnabled}"/>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Guide rate (×)" Style="{StaticResource Text.Label}"/>
                    <c:NumericBox Grid.Column="1" Width="72" HorizontalAlignment="Left"
                                  Min="0.01" Max="1.0" Step="0.05" DecimalPlaces="2"
                                  Value="{Binding Tracking.GuideRate}"
                                  IsEnabled="{Binding Tracking.MountActionsEnabled}"/>
                  </Grid>
                  <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="At meridian" Style="{StaticResource Text.Label}"/>
                    <ComboBox Grid.Column="1" Width="160"
                              ItemsSource="{Binding Tracking.MeridianActions}"
                              SelectedItem="{Binding Tracking.MeridianAction}"
                              IsEnabled="{Binding Tracking.MountActionsEnabled}"/>
                    <Button Grid.Column="2" Content="Advanced…" Command="{Binding Tracking.AdvancedCommand}"
                            HorizontalAlignment="Right"/>
                  </Grid>
                </StackPanel>
              </c:Section.Body>
            </c:Section>

            <!-- ───── Limits ───── -->
            <c:Section Title="LIMITS" IconGeometry="{StaticResource Geo.Limits}">
              <c:Section.HeaderRight>
                <c:StatusBadge Status="{Binding Limits.StatusKind}"
                               Pulsing="{Binding Limits.StatusPulse}"
                               Text="{Binding Limits.StatusText}"
                               Visibility="{Binding Limits.StatusVisible, Converter={StaticResource BoolToVis}}"/>
              </c:Section.HeaderRight>
              <c:Section.Body>
                <StackPanel>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="92"/><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Horizon (°)" Style="{StaticResource Text.Label}"/>
                    <c:NumericBox Grid.Column="1" Width="72" HorizontalAlignment="Left"
                                  Min="-30" Max="30" Step="1" DecimalPlaces="0"
                                  Value="{Binding Limits.HorizonLimit}"/>
                    <TextBlock Grid.Column="2" Text="Overhead (°)" Style="{StaticResource Text.Label}"/>
                    <c:NumericBox Grid.Column="3" Width="72" HorizontalAlignment="Left"
                                  Min="60" Max="90" Step="1" DecimalPlaces="0"
                                  Value="{Binding Limits.OverheadLimit}"/>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="92"/><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Merid. E (min)" Style="{StaticResource Text.Label}"/>
                    <c:NumericBox Grid.Column="1" Width="72" HorizontalAlignment="Left"
                                  Min="-270" Max="270" Step="1" DecimalPlaces="0"
                                  Value="{Binding Limits.MeridianEastMin}"/>
                    <TextBlock Grid.Column="2" Text="Merid. W (min)" Style="{StaticResource Text.Label}"/>
                    <c:NumericBox Grid.Column="3" Width="72" HorizontalAlignment="Left"
                                  Min="-270" Max="270" Step="1" DecimalPlaces="0"
                                  Value="{Binding Limits.MeridianWestMin}"/>
                  </Grid>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="92"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sync limit (°)" Style="{StaticResource Text.Label}"/>
                    <c:NumericBox Grid.Column="1" Width="72"
                                  Min="0" Max="180" Step="1" DecimalPlaces="0"
                                  Value="{Binding Limits.SyncLimit}"/>
                    <TextBlock Grid.Column="2" Text="0 = disabled" Style="{StaticResource Text.Hint}" Margin="8,0,0,0"/>
                  </Grid>
                  <Button Content="Upload" Command="{Binding Limits.UploadCommand}" HorizontalAlignment="Right" MinWidth="100"/>
                </StackPanel>
              </c:Section.Body>
            </c:Section>

            <!-- ───── Advanced (collapsed by default) ───── -->
            <c:Section Title="ADVANCED" IconGeometry="{StaticResource Geo.Console}" IsExpanded="False">
              <c:Section.Body>
                <StackPanel>
                  <CheckBox Content="Notify on limits" IsChecked="{Binding Advanced.NotificationsEnabled}" Margin="0,0,0,6"/>
                  <CheckBox Content="Enable Verbose log file" IsChecked="{Binding Advanced.VerboseLog}" Margin="0,0,0,6"/>
                  <TextBlock Text="{Binding Advanced.LogPath}" Style="{StaticResource Text.Hint}"
                             TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                  <Button Content="Open Log Folder" Command="{Binding Advanced.OpenLogFolderCommand}"
                          HorizontalAlignment="Left" MinWidth="140"/>
                  <Button Content="NV Reset…"
                          Style="{StaticResource Btn.Danger}"
                          Command="{Binding ParkHome.NvResetCommand}"
                          HorizontalAlignment="Stretch"
                          Margin="0,6,0,0"/>
                </StackPanel>
              </c:Section.Body>
            </c:Section>
          </StackPanel>
        </ScrollViewer>

        <!-- RIGHT pane -->
        <Border Grid.Column="1" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,0,0,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14">
            <StackPanel>
              <!-- ───── Current Position ───── -->
              <c:Section Title="CURRENT POSITION" IconGeometry="{StaticResource Geo.Position}">
                <c:Section.Body>
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="RA"          Style="{StaticResource Text.Label}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Position.RightAscension}" Style="{StaticResource Text.Mono}"/>
                    <TextBlock Grid.Row="1" Text="Dec"         Style="{StaticResource Text.Label}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Position.Declination}"   Style="{StaticResource Text.Mono}"/>
                    <TextBlock Grid.Row="2" Text="Altitude"    Style="{StaticResource Text.Label}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Position.Altitude}"      Style="{StaticResource Text.Mono}"/>
                    <TextBlock Grid.Row="3" Text="Azimuth"     Style="{StaticResource Text.Label}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Position.Azimuth}"       Style="{StaticResource Text.Mono}"/>
                    <TextBlock Grid.Row="4" Text="Pier side"   Style="{StaticResource Text.Label}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Position.PierSide}"      Style="{StaticResource Text.Mono}"/>
                    <TextBlock Grid.Row="5" Text="LST / mount" Style="{StaticResource Text.Label}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Position.Lst}"           Style="{StaticResource Text.Mono}"/>
                  </Grid>
                </c:Section.Body>
              </c:Section>

              <!-- ───── 3D Visualizer ───── -->
              <c:Section Title="VISUALIZER" IconGeometry="{StaticResource Geo.Position}">
                <c:Section.Body>
                  <!-- Height binds to own ActualWidth so the viewport stays
                       square regardless of pane width. -->
                  <c:MountVisualizer DataContext="{Binding Visualizer}"
                                     Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"/>
                </c:Section.Body>
              </c:Section>

              <!-- ───── Park / Home / Go To ───── -->
              <c:Section Title="PARK / HOME / GO TO" IconGeometry="{StaticResource Geo.Park}">
                <c:Section.Body>
                  <StackPanel>
                    <UniformGrid Columns="2" Margin="0,0,0,6">
                      <Button Content="Park"     Command="{Binding ParkHome.ParkCommand}"     Margin="0,0,3,3"/>
                      <Button Content="Unpark"   Command="{Binding ParkHome.UnparkCommand}"   Margin="3,0,0,3"/>
                      <Button Content="Set Home" Command="{Binding ParkHome.SetHomeCommand}"  Margin="0,3,3,0"/>
                      <Button Content="Go Home"  Command="{Binding ParkHome.SearchHomeCommand}" Margin="3,3,0,0"/>
                    </UniformGrid>
                    <Button Content="Set Park Here" Command="{Binding ParkHome.SetParkHereCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                    <Button Style="{StaticResource Btn.Primary}"
                            Command="{Binding ParkHome.SlewToTargetCommand}"
                            HorizontalAlignment="Stretch" Margin="0,0,0,6">
                      <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12" Margin="0,0,8,0" Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              Data="{StaticResource Geo.Target}"/>
                        <TextBlock Text="Slew to Target…" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </c:Section.Body>
              </c:Section>

              <!-- ───── Manual Slew pad ───── -->
              <c:Section Title="MANUAL SLEW" IconGeometry="{StaticResource Geo.Slew}">
                <c:Section.Body>
                  <StackPanel>
                    <c:SlewPad PadVM="{Binding ParkHome}"
                               IsArmed="{Binding ParkHome.MountActionsEnabled}"
                               Height="220" Margin="0,0,0,6"/>
                    <Button Content="Slew Rate Info…" Command="{Binding ParkHome.SlewRateInfoCommand}"
                            HorizontalAlignment="Stretch"/>
                  </StackPanel>
                </c:Section.Body>
              </c:Section>

              <c:StatusBadge Status="{Binding ClientCountKind}"
                             Pulsing="{Binding ClientCountPulse}"
                             Text="{Binding ClientCountText}"
                             Margin="4,8,0,0"/>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- THIRD column: focuser + future device sections (rotator, dome, weather…). -->
        <Border Grid.Column="2" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,0,0,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14">
            <StackPanel>
              <!-- ───── Focuser ───── -->
              <c:Section Title="FOCUSER" IconGeometry="{StaticResource Geo.Focuser}"
                         Visibility="{Binding Focuser.IsAvailable, Converter={StaticResource BoolToVis}}">
                <c:Section.HeaderRight>
                  <c:StatusBadge Status="{Binding Focuser.StatusKind}"
                                 Pulsing="{Binding Focuser.StatusPulse}"
                                 Text="{Binding Focuser.StatusText}"/>
                </c:Section.HeaderRight>
                <c:Section.Body>
                  <StackPanel>
                    <!-- Focuser # selector — only shown when more than one is detected. -->
                    <Grid Margin="0,0,0,6"
                          Visibility="{Binding Focuser.FocuserSelectionVisible, Converter={StaticResource BoolToVis}}">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Focuser #" Style="{StaticResource Text.Label}"/>
                      <ComboBox Grid.Column="1" Width="80" HorizontalAlignment="Left"
                                ItemsSource="{Binding Focuser.FocuserOptions}"
                                SelectedItem="{Binding Focuser.ActiveIndex}"
                                IsEnabled="{Binding Focuser.MountActionsEnabled}"/>
                    </Grid>

                    <!-- Position readout (live, polled). -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Position" Style="{StaticResource Text.Label}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Focuser.Position}" Style="{StaticResource Text.Mono}" Margin="0,0,8,0"/>
                      <TextBlock Grid.Column="2" Text="{Binding Focuser.PositionMm}" Style="{StaticResource Text.Hint}"/>
                    </Grid>

                    <!-- Goto target. -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Goto" Style="{StaticResource Text.Label}"/>
                      <c:NumericBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                    Min="{Binding Focuser.MinSteps}" Max="{Binding Focuser.MaxSteps}" Step="1" DecimalPlaces="0"
                                    Value="{Binding Focuser.TargetPosition}"
                                    IsEnabled="{Binding Focuser.MountActionsEnabled}"/>
                      <Button Grid.Column="2" Style="{StaticResource Btn.SmPrimary}"
                              Content="Goto" Command="{Binding Focuser.GotoCommand}" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- Manual move + halt. Each click moves StepSize via :Fr[±N]#. -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Move" Style="{StaticResource Text.Label}"/>
                      <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource Btn.Sm}" Content="◀ In"  Command="{Binding Focuser.MoveInCommand}"  Margin="0,0,4,0"/>
                        <Button Style="{StaticResource Btn.SmPrimary}" Content="Halt" Command="{Binding Focuser.HaltCommand}" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource Btn.Sm}" Content="Out ▶" Command="{Binding Focuser.MoveOutCommand}"/>
                      </StackPanel>
                    </Grid>

                    <!-- Step size (per-click, in motor steps). -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Step" Style="{StaticResource Text.Label}"/>
                      <c:NumericBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                    Min="1" Max="100000" Step="10" DecimalPlaces="0"
                                    Value="{Binding Focuser.StepSize}"
                                    IsEnabled="{Binding Focuser.MountActionsEnabled}"/>
                    </Grid>

                    <!-- Rate (governs In/Out, Goto, Go Home — OnStepX goto-rate presets 5..9). -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Rate" Style="{StaticResource Text.Label}"/>
                      <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                ItemsSource="{Binding Focuser.GotoRateOptions}"
                                DisplayMemberPath="Label"
                                SelectedValuePath="Value"
                                SelectedValue="{Binding Focuser.GotoRatePreset}"
                                IsEnabled="{Binding Focuser.MountActionsEnabled}"/>
                    </Grid>

                    <!-- Home / zero. -->
                    <UniformGrid Columns="3" Margin="0,0,0,6">
                      <Button Content="Set Home" Command="{Binding Focuser.SetHomeCommand}" Margin="0,0,3,0"/>
                      <Button Content="Go Home"  Command="{Binding Focuser.GoHomeCommand}"  Margin="3,0,3,0"/>
                      <Button Content="Zero"     Command="{Binding Focuser.ZeroCommand}"    Margin="3,0,0,0"/>
                    </UniformGrid>

                    <!-- Backlash. -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Backlash" Style="{StaticResource Text.Label}"/>
                      <c:NumericBox Grid.Column="1" Width="80" HorizontalAlignment="Left"
                                    Min="0" Max="10000" Step="1" DecimalPlaces="0"
                                    Value="{Binding Focuser.Backlash}"
                                    IsEnabled="{Binding Focuser.MountActionsEnabled}"/>
                      <Button Grid.Column="2" Style="{StaticResource Btn.Sm}"
                              Content="Apply" Command="{Binding Focuser.ApplyBacklashCommand}" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- Limits readout (firmware-owned, read-only). -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Limits" Style="{StaticResource Text.Label}"/>
                      <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="min " Style="{StaticResource Text.Hint}"/>
                        <TextBlock Text="{Binding Focuser.MinSteps}" Style="{StaticResource Text.Mono}" Margin="0,0,12,0"/>
                        <TextBlock Text="max " Style="{StaticResource Text.Hint}"/>
                        <TextBlock Text="{Binding Focuser.MaxSteps}" Style="{StaticResource Text.Mono}"/>
                      </StackPanel>
                    </Grid>

                    <!-- Temperature + TCF. -->
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Temp" Style="{StaticResource Text.Label}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Focuser.TemperatureText}" Style="{StaticResource Text.Mono}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6"
                          IsEnabled="{Binding Focuser.TempCompAvailable}">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="TCF" Style="{StaticResource Text.Label}"/>
                      <CheckBox Grid.Column="1" Content="Enabled"
                                IsChecked="{Binding Focuser.TempCompEnabled}"/>
                    </Grid>
                    <Grid Margin="0,0,0,0"
                          IsEnabled="{Binding Focuser.TempCompAvailable}">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                      <TextBlock Text="Coeff (μm/°C)" Style="{StaticResource Text.Label}"/>
                      <c:NumericBox Grid.Column="1" Width="72"
                                    Min="0" Max="999" Step="0.5" DecimalPlaces="2"
                                    Value="{Binding Focuser.TcfCoeff}"
                                    IsEnabled="{Binding Focuser.MountActionsEnabled}"/>
                      <TextBlock Grid.Column="2" Text="band" Style="{StaticResource Text.Label}" Margin="8,0,4,0"/>
                      <c:NumericBox Grid.Column="3" Width="64"
                                    Min="1" Max="10000" Step="1" DecimalPlaces="0"
                                    Value="{Binding Focuser.TcfDeadband}"
                                    IsEnabled="{Binding Focuser.MountActionsEnabled}"/>
                      <Button Grid.Column="5" Style="{StaticResource Btn.Sm}"
                              Content="Apply" Command="{Binding Focuser.ApplyTcfCommand}"/>
                    </Grid>
                  </StackPanel>
                </c:Section.Body>
              </c:Section>

              <!-- Hint card when no focuser is configured on the board. -->
              <c:Section Title="FOCUSER" IconGeometry="{StaticResource Geo.Focuser}"
                         Visibility="{Binding Focuser.IsAvailable, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <c:Section.Body>
                  <TextBlock Style="{StaticResource Text.Hint}" TextWrapping="Wrap"
                             Text="No focuser detected on this OnStepX board. Enable AXIS4_DRIVER_MODEL (or higher) in the firmware Config.h and reflash to use a focuser here."/>
                </c:Section.Body>
              </c:Section>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </DockPanel>
  </Border>
</Window>
