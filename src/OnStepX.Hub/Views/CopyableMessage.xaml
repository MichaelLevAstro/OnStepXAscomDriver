<Window x:Class="ASCOM.OnStepX.Views.CopyableMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:ASCOM.OnStepX.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="OnStepX"
        Width="640" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="{DynamicResource Font.Sans}" FontSize="13"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="38" GlassFrameThickness="0" UseAeroCaptionButtons="False" CornerRadius="0" ResizeBorderThickness="6"/>
  </shell:WindowChrome.WindowChrome>

  <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
    <DockPanel>
      <!-- Mini titlebar -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel}" Height="38"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
        <Grid>
          <TextBlock x:Name="TitleText" VerticalAlignment="Center" Margin="14,0,0,0" Style="{StaticResource Text.WindowTitle}"/>
          <Button HorizontalAlignment="Right" Style="{StaticResource Btn.WinClose}" Click="OnClose" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Width="10" Height="10" Stretch="Uniform"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.2" StrokeStartLineCap="Round"
                  Data="{StaticResource Geo.WinClose}"/>
          </Button>
        </Grid>
      </Border>

      <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.Panel2}"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0"
              Padding="14,10">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource Btn.Sm}" Content="Copy" Click="OnCopy" Margin="0,0,8,0"/>
          <Button Style="{StaticResource Btn.SmPrimary}" Content="OK" Click="OnClose" MinWidth="64"/>
        </StackPanel>
      </Border>

      <Border Padding="14" Background="{DynamicResource Brush.Bg}">
        <TextBox x:Name="BodyText"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="{DynamicResource Font.Mono}" FontSize="12"
                 Background="{DynamicResource Brush.PanelInset}"
                 BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"/>
      </Border>
    </DockPanel>
  </Border>
</Window>
