<Window x:Class="ASCOM.OnStepX.Views.SitesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:ASCOM.OnStepX.Controls"
        xmlns:cv="clr-namespace:ASCOM.OnStepX.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Sites"
        Width="780" Height="520"
        MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="{DynamicResource Font.Sans}" FontSize="13"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="38" GlassFrameThickness="0" UseAeroCaptionButtons="False" CornerRadius="0" ResizeBorderThickness="6"/>
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
  </Window.Resources>
  <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
    <DockPanel>
      <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel}" Height="38"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
        <Grid>
          <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
            <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"
                  Stroke="{DynamicResource Brush.TextDim}" StrokeThickness="1.6"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  Data="{StaticResource Geo.Pin}"/>
            <TextBlock Text="Sites" Style="{StaticResource Text.WindowTitle}"/>
          </StackPanel>
          <Button HorizontalAlignment="Right" Style="{StaticResource Btn.WinClose}" Click="OnCancelClose" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Width="10" Height="10" Stretch="Uniform"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.2" StrokeStartLineCap="Round"
                  Data="{StaticResource Geo.WinClose}"/>
          </Button>
        </Grid>
      </Border>

      <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.Panel2}"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0" Padding="14,10">
        <Grid>
          <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Hint}" VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource Btn.SmPrimary}"
                    Content="{Binding ApplyText}"
                    IsEnabled="{Binding ApplyEnabled}"
                    Command="{Binding ApplyCommand}" Margin="0,0,8,0"/>
            <Button Style="{StaticResource Btn.Sm}" Content="Close" Click="OnCancelClose" MinWidth="64"/>
          </StackPanel>
        </Grid>
      </Border>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- LIST (left) -->
        <Border Grid.Column="0" Background="{DynamicResource Brush.Panel}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
          <DockPanel>
            <Grid DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel2}" Margin="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="120"/><ColumnDefinition Width="130"/><ColumnDefinition Width="80"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="Name"      Style="{StaticResource Text.Label}" Margin="14,8,0,8"/>
              <TextBlock Grid.Column="1" Text="Latitude"  Style="{StaticResource Text.Label}" Margin="0,8"/>
              <TextBlock Grid.Column="2" Text="Longitude" Style="{StaticResource Text.Label}" Margin="0,8"/>
              <TextBlock Grid.Column="3" Text="Elev (m)"  Style="{StaticResource Text.Label}" Margin="0,8"/>
            </Grid>
            <ListBox ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                     Background="Transparent" BorderThickness="0" Padding="0">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="Padding" Value="0"/>
                  <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="0,0,0,1">
                          <Grid>
                            <Border x:Name="AccentBar" Width="2" HorizontalAlignment="Left" Background="{DynamicResource Brush.Accent}" Visibility="Collapsed"/>
                            <ContentPresenter Margin="14,8"/>
                          </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Panel2}"/>
                          </Trigger>
                          <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.AccentSoft}"/>
                            <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/><ColumnDefinition Width="120"/><ColumnDefinition Width="130"/><ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                      <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                               Fill="{DynamicResource Brush.Ok}"
                               Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}"/>
                      <TextBlock Text="{Binding Name}" FontFamily="{DynamicResource Font.Mono}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding LatitudeText}"  FontFamily="{DynamicResource Font.Mono}"/>
                    <TextBlock Grid.Column="2" Text="{Binding LongitudeText}" FontFamily="{DynamicResource Font.Mono}"/>
                    <TextBlock Grid.Column="3" Text="{Binding ElevationText}" FontFamily="{DynamicResource Font.Mono}"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>

        <!-- EDITOR (right) -->
        <Border Grid.Column="1" Padding="14">
          <StackPanel>
            <TextBlock Text="Name" Style="{StaticResource Text.Label}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="Latitude (DMS or decimal)" Style="{StaticResource Text.Label}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Latitude, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
            <TextBlock Text="Longitude (east-positive)" Style="{StaticResource Text.Label}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Longitude, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
            <TextBlock Text="Elevation (m)" Style="{StaticResource Text.Label}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Elevation, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,12"/>
            <Button Content="Load from current" Command="{Binding LoadFromCurrentCommand}" Margin="0,0,0,8"/>
            <UniformGrid Columns="3" Margin="0,0,0,8">
              <Button Content="Add"    Command="{Binding AddCommand}"    Margin="0,0,4,0"/>
              <Button Content="Update" Command="{Binding UpdateCommand}" Margin="2,0,2,0"/>
              <Button Content="Remove" Command="{Binding RemoveCommand}" Margin="4,0,0,0"/>
            </UniformGrid>
            <UniformGrid Columns="2">
              <Button Content="Import…" Command="{Binding ImportCommand}" Margin="0,0,4,0"/>
              <Button Content="Export…" Command="{Binding ExportCommand}" Margin="4,0,0,0"/>
            </UniformGrid>
          </StackPanel>
        </Border>
      </Grid>
    </DockPanel>
  </Border>
</Window>
