<Window x:Class="ASCOM.OnStepX.Views.AdvancedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:ASCOM.OnStepX.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Advanced Mount Settings"
        Width="500" Height="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="{DynamicResource Font.Sans}" FontSize="13"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="38" GlassFrameThickness="0" UseAeroCaptionButtons="False" CornerRadius="0" ResizeBorderThickness="0"/>
  </shell:WindowChrome.WindowChrome>

  <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
    <DockPanel>
      <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel}" Height="38"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
        <Grid>
          <TextBlock VerticalAlignment="Center" Margin="14,0" Style="{StaticResource Text.WindowTitle}" Text="Advanced Mount Settings"/>
          <Button HorizontalAlignment="Right" Style="{StaticResource Btn.WinClose}" Click="OnCancel" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Width="10" Height="10" Stretch="Uniform"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.2" StrokeStartLineCap="Round"
                  Data="{StaticResource Geo.WinClose}"/>
          </Button>
        </Grid>
      </Border>

      <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.Panel2}"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0"
              Padding="14,10">
        <Grid>
          <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Hint}" VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource Btn.Sm}" Content="Apply"  Command="{Binding ApplyCommand}" Margin="0,0,8,0"/>
            <Button Style="{StaticResource Btn.SmPrimary}" Content="OK" Click="OnOk" MinWidth="64" Margin="0,0,8,0"/>
            <Button Style="{StaticResource Btn.Sm}" Content="Cancel" Click="OnCancel" MinWidth="64"/>
          </StackPanel>
        </Grid>
      </Border>

      <Border Padding="14">
        <c:Section Title="Pier / Meridian Policy" IconGeometry="{StaticResource Geo.Tracking}">
          <c:Section.Body>
            <StackPanel>
              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Text="Preferred pier side" Style="{StaticResource Text.Label}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding PierOptions}" SelectedIndex="{Binding PreferredPierIndex}"/>
              </Grid>
              <TextBlock Style="{StaticResource Text.Hint}" TextWrapping="Wrap" Margin="0,0,0,12"
                         Text="Recommended: Best. Prevents spurious flips from plate-solve corrections near the meridian."/>
              <CheckBox Content="Pause at home on meridian flip" IsChecked="{Binding PauseAtHome}"/>
            </StackPanel>
          </c:Section.Body>
        </c:Section>
      </Border>
    </DockPanel>
  </Border>
</Window>
