<Window x:Class="ASCOM.OnStepX.Views.SlewTargetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:ASCOM.OnStepX.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Slew to Target"
        Width="780" Height="600"
        MinWidth="700" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="{DynamicResource Font.Sans}" FontSize="13"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="38" GlassFrameThickness="0" UseAeroCaptionButtons="False" CornerRadius="0" ResizeBorderThickness="6"/>
  </shell:WindowChrome.WindowChrome>
  <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
    <DockPanel>
      <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel}" Height="38"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
        <Grid>
          <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
            <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"
                  Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.6"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  Data="{StaticResource Geo.Target}"/>
            <TextBlock Text="Slew to Target" Style="{StaticResource Text.WindowTitle}"/>
          </StackPanel>
          <Button HorizontalAlignment="Right" Style="{StaticResource Btn.WinClose}" Click="OnClose" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Width="10" Height="10" Stretch="Uniform"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.2" StrokeStartLineCap="Round"
                  Data="{StaticResource Geo.WinClose}"/>
          </Button>
        </Grid>
      </Border>

      <!-- Top toolbar -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel2}"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="14,10">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Catalog" Style="{StaticResource Text.Label}" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <ComboBox Width="140" ItemsSource="{Binding Catalogs}" SelectedItem="{Binding SelectedCatalog}" Margin="0,0,16,0"/>
          <TextBlock Text="Filter" Style="{StaticResource Text.Label}" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox Width="220" Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
          <Button Style="{StaticResource Btn.Sm}" Content="Refresh" Command="{Binding RefreshCommand}"/>
        </StackPanel>
      </Border>

      <!-- Bottom: selection summary + slew/close -->
      <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.Panel2}"
              BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0" Padding="14,10">
        <StackPanel>
          <TextBlock Text="{Binding SelectedLabel}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
          <TextBlock Text="{Binding CoordsLabel}" Style="{StaticResource Text.Mono}" Margin="0,0,0,8"/>
          <StackPanel Orientation="Horizontal">
            <Button Style="{StaticResource Btn.Primary}" Content="Slew to Target"
                    Command="{Binding SlewCommand}" MinWidth="160" Margin="0,0,8,0"/>
            <Button Content="Close" Click="OnClose" MinWidth="80"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- DataGrid is the easiest virtualized 5-column list. -->
      <DataGrid ItemsSource="{Binding RowsView}" SelectedItem="{Binding SelectedRow}"
                AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                CanUserReorderColumns="False" CanUserResizeRows="False"
                IsReadOnly="True" GridLinesVisibility="None" HeadersVisibility="Column"
                SelectionMode="Single" SelectionUnit="FullRow"
                Background="{DynamicResource Brush.Panel}"
                Foreground="{DynamicResource Brush.Text}"
                BorderThickness="0"
                RowBackground="Transparent"
                AlternatingRowBackground="Transparent"
                EnableRowVirtualization="True"
                EnableColumnVirtualization="True"
                FontFamily="{DynamicResource Font.Mono}" FontSize="12">
        <DataGrid.ColumnHeaderStyle>
          <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel2}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
          </Style>
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Panel2}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.CellStyle>
          <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                  <!-- Selection highlight has to live on the cell, not the row,
                       because the default cell template paints its own background
                       on top of DataGridRow.Background and would otherwise erase
                       the row-level trigger color. -->
                  <Border x:Name="Bd"
                          Background="{TemplateBinding Background}"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter VerticalAlignment="Center"
                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.AccentSoft}"/>
                      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </DataGrid.CellStyle>
        <DataGrid.Columns>
          <DataGridTextColumn Header="ID"   Binding="{Binding Id}"   Width="80"/>
          <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
          <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="160"/>
          <DataGridTextColumn Header="RA"   Binding="{Binding RA}"   Width="90"/>
          <DataGridTextColumn Header="Dec"  Binding="{Binding Dec}"  Width="90"/>
        </DataGrid.Columns>
      </DataGrid>
    </DockPanel>
  </Border>
</Window>
